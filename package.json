  "description": "Cursor OpenAI-compatible proxy gateway with Direct Gateway, account pool admin, Docker deployment, and NewAPI support.",
  "type": "module",
  "scripts": {
    "start": "node ./cursor-direct-gateway.mjs",
    "start:direct": "node ./cursor-direct-gateway.mjs",
