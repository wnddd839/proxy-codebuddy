# Copy this file to .env before running docker compose or local start.
CURSOR_DIRECT_API_KEY=replace-with-a-long-random-api-key
CURSOR_DIRECT_ADMIN_PASSWORD=replace-with-a-long-admin-password

CURSOR_DIRECT_REQUIRE_API_KEY=true
CURSOR_DIRECT_HOST=0.0.0.0
CURSOR_DIRECT_PORT=32126
CURSOR_DIRECT_AUTH_PATH=/data/auth.json
CURSOR_DIRECT_ACCOUNTS_PATH=/data/direct-accounts.json
CURSOR_DIRECT_API_BASE_URL=https://api2.cursor.sh
CURSOR_DIRECT_AGENT_HOST=agentn.api5.cursor.sh
CURSOR_DIRECT_CLIENT_VERSION=cli-2026.05.24-dda726e
CURSOR_DIRECT_IDLE_MS=6000
CURSOR_DIRECT_TIMEOUT_MS=60000
CURSOR_DIRECT_STREAM_KEEPALIVE_MS=15000
CURSOR_DIRECT_MODELS_CACHE_TTL_MS=300000
CURSOR_DIRECT_AUTH_CACHE_TTL_MS=5000
CURSOR_DIRECT_OAUTH_CACHE_TTL_MS=1000
CURSOR_DIRECT_PARSE_MAX_DEPTH=8
CURSOR_DIRECT_PARSE_MAX_FIELDS=6000
CURSOR_DIRECT_PARSE_MAX_STRINGS=3000
CURSOR_DIRECT_PARSE_MAX_STRING_BYTES=32000
CURSOR_DIRECT_PARSE_MAX_NESTED_BYTES=256000
CURSOR_DIRECT_PARSE_MAX_FRAME_BYTES=4194304
CURSOR_DIRECT_PARSE_MAX_TOTAL_BYTES=8388608
CURSOR_DIRECT_LOG_LEVEL=info

# CodeBuddy protocol direct (recommended)
CURSOR_DIRECT_CODEBUDDY_TRANSPORT=protocol_direct
CURSOR_DIRECT_CODEBUDDY_SITE=domestic
CURSOR_DIRECT_CODEBUDDY_INTERNET_ENVIRONMENT=internal
CURSOR_DIRECT_CODEBUDDY_BASE_URL=https://www.codebuddy.cn
CODEBUDDY_PROXY_ACCOUNTS_PATH=/data/codebuddy-accounts.json

# Public nginx port used by compose.yaml.
CURSOR_PROXY_PUBLIC_PORT=32124
